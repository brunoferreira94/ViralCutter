# Copy this file to .env and fill the values for local development.
# This project automatically loads .env if it exists.

# General GitHub token aliases supported by CLI and app
GITHUB_TOKEN=
GH_TOKEN=

# Optional OAuth values for GitHub Copilot web login
COPILOT_OAUTH_CLIENT_ID=
COPILOT_OAUTH_CLIENT_SECRET=

# Optional GitHub Copilot token for testing the CLI and app without web login
COPILOT_GITHUB_TOKEN=

# Optional host binding for WebUI/FastAPI
VIRALCUTTER_HOST=127.0.0.1

# Optional runtime log levels
ORT_LOGGING_LEVEL=3
TF_CPP_MIN_LOG_LEVEL=3
